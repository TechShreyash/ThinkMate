# For a comprehensive guide on what each variable does and how to tune it,
# see docs/development/configuration.md

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# === LLM (OpenAI-compatible endpoint) ===
# Local: LM Studio http://localhost:1234/v1 | Ollama http://localhost:11434/v1
# Cloud: OpenAI https://api.openai.com/v1 | OpenRouter https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=none
LLM_MODEL=gpt-4o
# Optional separate model for memory extraction/compression (falls back to LLM_MODEL).
LLM_EXTRACTION_MODEL=gpt-4o-mini
# Structured-output strategy:
#   json_object  -> works with Gemini/Ollama/LM Studio/most proxies (DEFAULT, recommended)
#   native_parse -> only true OpenAI structured outputs (beta.chat.completions.parse)
LLM_STRUCTURED_MODE=json_object
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECS=0.5
REPLY_TEMPERATURE=0.7
EXTRACTION_TEMPERATURE=0.1

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=thinkmate_db
# Audit-log entries auto-expire after this many days (TTL index).
AUDIT_LOG_RETENTION_DAYS=30

# === Memory tuning ===
CHAT_BUFFER_MAX_CHARS=10000     # buffer char count that triggers extraction
CHAT_BUFFER_TRIM=10             # newest messages kept as active context after extraction
CHAT_BUFFER_HARD_CAP=200        # absolute max messages retained (safety net)
USER_MEMORY_BUDGET_CHARS=4000   # compiled-memory size that triggers compression (keep >= ~600)
COMPRESSION_COOLDOWN_SECS=300   # min seconds between compressions per user
CHARS_PER_TOKEN=4

# === Batching / responsiveness ===
MESSAGE_BATCH_DELAY_SECS=1.5    # idle gap before a batch is processed
MAX_BATCH_DELAY_SECS=5.0        # hard deadline so a spammer can't postpone forever
USER_STATE_TTL_SECS=1800        # idle per-user in-memory state is evicted after this

# === Input/Output guards ===
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECS=10.0
MAX_QUEUED_MESSAGES=10
MAX_INPUT_CHARS=2500     # ignore inbound messages longer than this (anti-abuse, not a chat cap)
MAX_RESPONSE_CHARS=2000  # generous ceiling for reply length; actual length is matched to the user

# === Group chat / ambient replies ===
GROUP_AMBIENT_COOLDOWN_SECS=90   # min seconds between ambient (un-addressed) chime-ins per group
GROUP_AMBIENT_BASE_RATE=0.25     # base chime-in probability before affinity weighting (keep <= ~0.4)
GROUP_CONTEXT_SCAN_EVERY=12      # group messages between affinity-gated context-scan calls
AFFINITY_DEFAULT=0.5             # starting affinity (0-1) for a new chat:user member

# === Persona / features ===
PERSONA_FILE=persona.md
ENABLE_MESSAGE_REACTIONS=True

# === Observability / ops ===
ADMIN_USER_IDS=                 # CSV of Telegram user ids for /health & /metrics (empty -> DM-only)
METRICS_LOG_INTERVAL_SECS=0     # seconds between periodic metrics-summary log lines (0 disables)

# === Consolidation (Phase 11) ===
CONSOLIDATION_INTERVAL_SECS=0        # per-user cadence for the "dreaming" pass; 0 disables the dreaming pass
CONSOLIDATION_SCAN_INTERVAL_SECS=3600  # how often the scheduler scans for due users
CONSOLIDATION_MAX_USERS_PER_SCAN=50  # max due users processed per scan (bounds work/LLM volume)
CONSOLIDATION_MIN_ITEMS=8            # min stored items (facts+beliefs+events) before a user is eligible
MAX_INSIGHTS=5                       # hard cap on the dedicated behavioral-insights list
