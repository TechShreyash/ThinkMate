# For a comprehensive guide on what each environment variable does and how to tune them,
# see docs/development/configuration.md (file:///d:/ThinkMate/docs/development/configuration.md)

# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# LLM Base configuration (OpenAI-compatible)
# Local options: 
# - LM Studio: http://localhost:1234/v1
# - Ollama: http://localhost:11434/v1
# Cloud options:
# - OpenAI: https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=none

# Conversational LLM Model
# Examples: gpt-4o, llama3:8b, meta-llama/llama-3-8b-instruct:free
LLM_MODEL=gpt-4o

# Extraction LLM Model (Optional - falls back to LLM_MODEL if empty)
LLM_EXTRACTION_MODEL=gpt-4o-mini

# MongoDB Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=thinkmate_db

# Memory Tuning Settings
CHAT_BUFFER_MAX_CHARS=4000
CHAT_BUFFER_TRIM=5
USER_MEMORY_BUDGET_CHARS=4000
CHARS_PER_TOKEN=4
MESSAGE_BATCH_DELAY_SECS=1.5
MAX_BATCH_DELAY_SECS=5.0

# Input/Output Guards
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECS=10.0
MAX_QUEUED_MESSAGES=10
MAX_INPUT_CHARS=1000
MAX_RESPONSE_CHARS=1000

# Persona Settings
PERSONA_FILE=persona.md
