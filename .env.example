# For a comprehensive guide on what each variable does and how to tune it,
# see docs/development/configuration.md

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
# Enable/disable publishing the command menu to Telegram on startup. Default is True.
TELEGRAM_PUBLISH_COMMANDS=True

# === MongoDB ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=thinkmate_db
# Audit-log entries auto-expire after this many days (TTL index).
AUDIT_LOG_RETENTION_DAYS=30

# === LLM (OpenAI-compatible endpoint) ===
# Local: LM Studio http://localhost:1234/v1 | Ollama http://localhost:11434/v1
# Cloud: OpenAI https://api.openai.com/v1 | OpenRouter https://openrouter.ai/api/v1
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=none
LLM_MODEL=gpt-4o
# Optional separate model for memory extraction/compression (falls back to LLM_MODEL).
LLM_EXTRACTION_MODEL=gpt-4o-mini
# Structured-output strategy:
#   json_object  -> works with Gemini/Ollama/LM Studio/most proxies (DEFAULT, recommended)
#   native_parse -> only true OpenAI structured outputs (beta.chat.completions.parse)
LLM_STRUCTURED_MODE=json_object
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECS=0.5
# Per-request client timeout, in seconds. Keep this ABOVE your LLM proxy/server's
# own request ceiling so the proxy errors first instead of the client abandoning a
# still-running generation and re-spawning it on retry (which causes duplicate
# upstream work under load). Default 610 sits just above a 600s proxy cap. Raise it
# if your proxy allows longer non-streaming generations.
LLM_REQUEST_TIMEOUT_SECS=610

# === Memory tuning ===
CHAT_BUFFER_MAX_CHARS=10000     # buffer char count that triggers extraction
NEW_USER_EXTRACTION_CHARS=1000  # lower trigger for new/sparse users so their profile builds fast
NEW_USER_MEMORY_THRESHOLD=5     # stored memory items below this = "new" user (uses the lower trigger)
CHAT_BUFFER_TRIM=10             # newest messages kept as active context after extraction
CHAT_BUFFER_HARD_CAP=200        # absolute max messages retained (safety net)
USER_MEMORY_BUDGET_CHARS=4000   # compiled-memory size that triggers compression (keep >= ~600)
COMPRESSION_COOLDOWN_SECS=300   # min seconds between compressions per user
CHARS_PER_TOKEN=4

# === Batching / responsiveness ===
MESSAGE_BATCH_DELAY_SECS=1.5    # idle gap before a batch is processed
MAX_BATCH_DELAY_SECS=5.0        # hard deadline so a spammer can't postpone forever
USER_STATE_TTL_SECS=1800        # idle per-user in-memory state is evicted after this

# === Input/Output guards ===
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECS=10.0
STALE_MESSAGE_SECS=60.0  # ignore messages older than this at processing time (0 disables); prevents replying to / throttling on backlog after a restart or catch-up
MAX_QUEUED_MESSAGES=10
MAX_INPUT_CHARS=2500     # ignore inbound messages longer than this (anti-abuse, not a chat cap)
MAX_RESPONSE_CHARS=2000  # generous ceiling for reply length; actual length is matched to the user

# === Group chat / ambient replies ===
GROUP_AMBIENT_COOLDOWN_SECS=90   # min seconds between ambient (un-addressed) chime-ins per group
GROUP_AMBIENT_BASE_RATE=0.25     # base chime-in probability before affinity weighting (keep <= ~0.4)
GROUP_CONTEXT_SCAN_EVERY=12      # group messages between affinity-gated context-scan calls
AFFINITY_DEFAULT=0.5             # starting affinity (0-1) for a new chat:user member

# === Group chat / implicit addressing & spam ===
GROUP_IMPLICIT_RECENCY_SECS=120.0     # max seconds after the bot speaks for a follow-up to count as implicitly addressed
GROUP_IMPLICIT_RECENCY_MAX_MSGS=4     # max intervening human messages since the bot spoke for an implicit follow-up
GROUP_IMPLICIT_COOLDOWN_SECS=30.0     # min seconds between implicit direct replies per group (anti-noise throttle)
GROUP_MASS_TAG_SPAM_THRESHOLD=5       # distinct @mentions above which a single message is mass-tag spam (strict >)
GROUP_SPAM_BURST_SIMILARITY=0.85      # mention-stripped similarity ratio (0-1) at/above which messages are near-identical
GROUP_SPAM_BURST_COUNT=3              # near-identical messages within the window that classify a greeting burst
GROUP_SPAM_BURST_WINDOW_SECS=60.0     # time window for counting near-identical greeting-burst messages
GROUP_SPAM_BURST_TRACK_MAX=20         # hard cap on tracked recent messages per chat (bounds memory)

# === Persona / features ===
PERSONA_FILE=persona.md
# Name the bot answers to in groups (in addition to its @username mention).
# Blank -> uses the bot's Telegram first name from get_me().
BOT_NAME=ThinkMate
ENABLE_MESSAGE_REACTIONS=True

# === Commands (rename / disable, optional) ===
# Every built-in command can be renamed to a different trigger and/or disabled from
# the environment. Defaults: the trigger equals the command key and it is enabled, so
# you only set the ones you want to change. The in-chat command list reflects these live.
#   CMD_<KEY>_NAME    -> trigger to bind the command under (1-32 chars, letters/digits/_,
#                        a leading "/" is stripped). Invalid or duplicate names fall back
#                        to the default key.
#   CMD_<KEY>_ENABLED -> True/False; a disabled command is unregistered and hidden.
# KEYS: start onboard checkins profile reset reactions quiet chatty groupbot groupmode health metrics
# Only the entry-point command (CMD_START_NAME) is published to Telegram's "/" menu on
# startup; every other command is discoverable through the in-chat guide opened from it.
# Examples:
#   CMD_START_NAME=chatbot      # map /start to /chatbot (the bot's main entry point)
#   CMD_PROFILE_NAME=memories   # map /profile to /memories
#   CMD_RESET_ENABLED=False     # remove /reset entirely

# === Observability / ops ===
ADMIN_USER_IDS=                 # CSV of Telegram user ids for /health & /metrics (empty -> DM-only)
METRICS_LOG_INTERVAL_SECS=0     # seconds between periodic metrics-summary log lines (0 disables)
METRICS_PERSIST_INTERVAL_SECS=300  # seconds between persisting /metrics state to MongoDB so it survives restarts (0 disables periodic flush; startup-load + shutdown-flush still run)
LOGS_CHANNEL_ID=                # Telegram channel/chat id that receives forwarded operational events & WARNING+ logs (empty disables forwarding)
FORWARD_DIAGNOSTICS=False       # early-phase: also forward per-message routing decisions (group addressed/implicit/ambient/spam, throttle, blocked) to LOGS_CHANNEL_ID — noisy, turn off once trusted

# === Consolidation (Phase 11) ===
CONSOLIDATION_INTERVAL_SECS=0        # per-user cadence for the "dreaming" pass; 0 disables the dreaming pass
CONSOLIDATION_SCAN_INTERVAL_SECS=3600  # how often the scheduler scans for due users
CONSOLIDATION_MAX_USERS_PER_SCAN=50  # max due users processed per scan (bounds work/LLM volume)
CONSOLIDATION_MIN_ITEMS=8            # min stored items (facts+beliefs+events) before a user is eligible
MAX_INSIGHTS=5                       # hard cap on the dedicated behavioral-insights list

# --- Engagement / mood history (Phase 12) ---
MAX_MOOD_HISTORY=10                  # cap on stored mood-history entries (bounded mood trend)

# --- Proactive check-ins (Phase 12) ---
PROACTIVE_INTERVAL_SECS=0.0          # scheduler scan period; 0 = DISABLED (master switch)
PROACTIVE_INACTIVITY_SECS=172800     # inactivity before a user is due (default 2 days)
PROACTIVE_MIN_INTERVAL_SECS=259200   # min time between nudges per user (default 3 days)
PROACTIVE_MAX_PER_SCAN=20            # max check-ins sent per scan (bounds work/LLM volume)
PROACTIVE_MIN_ITEMS=3                # min facts+beliefs+events needed to ground a check-in
PROACTIVE_MAX_UNANSWERED=3           # auto-pause after this many delivered check-ins with no reply (chat/cmd); engaging resets it. 0 disables
PROACTIVE_QUIET_START_HOUR=22        # quiet window start (UTC hour 0-23; UTC-only)
PROACTIVE_QUIET_END_HOUR=7           # quiet window end (UTC hour 0-23; UTC-only)
